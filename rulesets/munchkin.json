{
  "schema_version": "0.5.0",
  "ruleset": {
    "name": "Munchkin (Simplified)",
    "description": "## Munchkin (Simplified)\n\nCompetitive dungeon-delving card game for 3–6 players (modelled with 4).\n\n**Goal:** be the first to reach **Level 10** by killing monsters.\n\n**Turn structure:**\n1. *Door* — kick open the dungeon door, draw a Door card\n2. *Combat* — fight the monster (or look for trouble); other players may help or hinder\n3. *Loot* — draw treasure cards on victory\n4. *End of turn* — discard down to 5 hand cards (charity rule)\n\n**Key mechanics:**\n- Other players may **help** the active player fight (split the treasure)\n- Other players may **hinder** the fight with Bad Stuff cards\n- Equipment cards raise your combat strength\n- Card types are modelled as generic entities; individual card text is in rule descriptions",
    "source": "Steve Jackson Games (simplified model)"
  },
  "entities": [
    { "id": "moderator",    "name": "Moderator",    "type": "game_authority" },
    { "id": "player_1",     "name": "Player 1",     "type": "player" },
    { "id": "player_2",     "name": "Player 2",     "type": "player" },
    { "id": "player_3",     "name": "Player 3",     "type": "player" },
    { "id": "player_4",     "name": "Player 4",     "type": "player" },
    { "id": "dungeon_deck", "name": "Dungeon Deck", "type": "game_component" },
    { "id": "monster",      "name": "Monster",      "type": "game_component" },
    { "id": "treasure",     "name": "Treasure",     "type": "game_component" }
  ],
  "cohorts": {
    "all_players": ["player_1", "player_2", "player_3", "player_4"],
    "p1_others":   ["player_2", "player_3", "player_4"],
    "p2_others":   ["player_1", "player_3", "player_4"],
    "p3_others":   ["player_1", "player_2", "player_4"],
    "p4_others":   ["player_1", "player_2", "player_3"]
  },
  "phases": ["door", "combat", "loot", "end_of_turn"],
  "rules": [
    {
      "id": "r01",
      "rule_name": "kick_open_door",
      "rule_type": "obligation",
      "phase": "door",
      "authority_entity": "moderator",
      "subject_entity": "@all_players",
      "authority_utility": 0,
      "subject_utility": 0,
      "affected_entity": "dungeon_deck",
      "affected_utility": -1,
      "description": "The active player must kick open the dungeon door as the first action of their turn, drawing a Door card face-up"
    },
    {
      "id": "r02",
      "rule_name": "may_look_for_trouble",
      "rule_type": "permission",
      "phase": "combat",
      "authority_entity": "moderator",
      "subject_entity": "@all_players",
      "authority_utility": 0,
      "subject_utility": 1,
      "affected_entity": "monster",
      "affected_utility": -1,
      "description": "If no monster appeared when kicking the door, the active player may play a monster from their hand to fight it"
    },
    {
      "id": "r03",
      "rule_name": "wins_combat",
      "rule_type": "permission",
      "phase": "combat",
      "authority_entity": "moderator",
      "subject_entity": "@all_players",
      "authority_utility": 0,
      "subject_utility": 1,
      "affected_entity": "monster",
      "affected_utility": -1,
      "description": "If the active player's level plus item bonuses exceed the monster's level, they kill it and gain one level"
    },
    {
      "id": "r04",
      "rule_name": "bad_stuff_on_loss",
      "rule_type": "prohibition",
      "phase": "combat",
      "authority_entity": "moderator",
      "subject_entity": "@all_players",
      "authority_utility": 0,
      "subject_utility": -1,
      "affected_entity": "monster",
      "affected_utility": 1,
      "description": "If the active player cannot beat the monster and fails to run away, the monster's bad stuff occurs (lose levels, items, or worse)"
    },
    {
      "id": "r05",
      "rule_name": "p1_may_help",
      "rule_type": "permission",
      "phase": "combat",
      "authority_entity": "moderator",
      "subject_entity": "player_1",
      "authority_utility": 0,
      "subject_utility": 1,
      "affected_entity": "@p1_others",
      "affected_utility": 1,
      "description": "Player 1 may offer to help another player in combat, adding their level and items to the fight in exchange for a negotiated share of the treasure"
    },
    {
      "id": "r06",
      "rule_name": "p2_may_help",
      "rule_type": "permission",
      "phase": "combat",
      "authority_entity": "moderator",
      "subject_entity": "player_2",
      "authority_utility": 0,
      "subject_utility": 1,
      "affected_entity": "@p2_others",
      "affected_utility": 1,
      "description": "Player 2 may offer to help another player in combat, adding their level and items to the fight in exchange for a negotiated share of the treasure"
    },
    {
      "id": "r07",
      "rule_name": "p3_may_help",
      "rule_type": "permission",
      "phase": "combat",
      "authority_entity": "moderator",
      "subject_entity": "player_3",
      "authority_utility": 0,
      "subject_utility": 1,
      "affected_entity": "@p3_others",
      "affected_utility": 1,
      "description": "Player 3 may offer to help another player in combat, adding their level and items to the fight in exchange for a negotiated share of the treasure"
    },
    {
      "id": "r08",
      "rule_name": "p4_may_help",
      "rule_type": "permission",
      "phase": "combat",
      "authority_entity": "moderator",
      "subject_entity": "player_4",
      "authority_utility": 0,
      "subject_utility": 1,
      "affected_entity": "@p4_others",
      "affected_utility": 1,
      "description": "Player 4 may offer to help another player in combat, adding their level and items to the fight in exchange for a negotiated share of the treasure"
    },
    {
      "id": "r09",
      "rule_name": "p1_may_hinder",
      "rule_type": "permission",
      "phase": "combat",
      "authority_entity": "moderator",
      "subject_entity": "player_1",
      "authority_utility": 0,
      "subject_utility": 1,
      "affected_entity": "@p1_others",
      "affected_utility": -1,
      "description": "Player 1 may play cards during another player's combat to boost the monster, add obstacles, or otherwise sabotage the fight"
    },
    {
      "id": "r10",
      "rule_name": "p2_may_hinder",
      "rule_type": "permission",
      "phase": "combat",
      "authority_entity": "moderator",
      "subject_entity": "player_2",
      "authority_utility": 0,
      "subject_utility": 1,
      "affected_entity": "@p2_others",
      "affected_utility": -1,
      "description": "Player 2 may play cards during another player's combat to boost the monster, add obstacles, or otherwise sabotage the fight"
    },
    {
      "id": "r11",
      "rule_name": "p3_may_hinder",
      "rule_type": "permission",
      "phase": "combat",
      "authority_entity": "moderator",
      "subject_entity": "player_3",
      "authority_utility": 0,
      "subject_utility": 1,
      "affected_entity": "@p3_others",
      "affected_utility": -1,
      "description": "Player 3 may play cards during another player's combat to boost the monster, add obstacles, or otherwise sabotage the fight"
    },
    {
      "id": "r12",
      "rule_name": "p4_may_hinder",
      "rule_type": "permission",
      "phase": "combat",
      "authority_entity": "moderator",
      "subject_entity": "player_4",
      "authority_utility": 0,
      "subject_utility": 1,
      "affected_entity": "@p4_others",
      "affected_utility": -1,
      "description": "Player 4 may play cards during another player's combat to boost the monster, add obstacles, or otherwise sabotage the fight"
    },
    {
      "id": "r13",
      "rule_name": "gains_treasure",
      "rule_type": "permission",
      "phase": "loot",
      "authority_entity": "moderator",
      "subject_entity": "@all_players",
      "authority_utility": 0,
      "subject_utility": 1,
      "affected_entity": "treasure",
      "affected_utility": -1,
      "description": "After killing a monster, the active player draws treasure cards equal to the monster's treasure value"
    },
    {
      "id": "r14",
      "rule_name": "must_give_charity",
      "rule_type": "obligation",
      "phase": "end_of_turn",
      "authority_entity": "moderator",
      "subject_entity": "@all_players",
      "authority_utility": 0,
      "subject_utility": -1,
      "description": "At the end of their turn, the active player must give any cards over five to the lowest-level player (if tied, active player chooses)"
    },
    {
      "id": "r15",
      "rule_name": "wins_at_level_10",
      "rule_type": "permission",
      "authority_entity": "moderator",
      "subject_entity": "@all_players",
      "authority_utility": 0,
      "subject_utility": 1,
      "description": "The first player to reach Level 10 by killing a monster wins the game immediately"
    }
  ]
}
