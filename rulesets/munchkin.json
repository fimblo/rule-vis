  "ruleset": {
    "name": "Munchkin (Simplified)",
    "description": "A dungeon-delving card game for 3-6 players. Players fight monsters, collect treasure, and backstab each other to be first to reach Level 10. Card types are modelled as generic entities rather than individual cards; conditional card abilities are noted in rule descriptions but not encoded.",
    "source": "Steve Jackson Games (simplified model)"
  },
