{
  "schema_version": "0.4.0",
  "ruleset": {
    "name": "Werewolf",
    "description": "## Werewolf\n\nSocial deduction game for 5 players. Two factions compete in alternating night/day cycles.\n\n**Factions:**\n- **Village** — Seer, Doctor, and two Villagers\n- **Werewolf** — one hidden wolf\n\n**Goal:**\n- Village wins by eliminating the Werewolf through majority vote\n- Werewolf wins when it equals or outnumbers surviving villagers\n\n**Roles:**\n- *Werewolf* — secretly eliminates one player each night\n- *Seer* — inspects one player's role each night\n- *Doctor* — protects one player from elimination each night\n- *Villagers* — vote only; no night action\n\nAll roles are secret. No player may reveal their role.",
    "source": "Traditional / public domain"
  },
  "entities": [
    { "id": "moderator",   "name": "Moderator",    "type": "game_authority",  "faction": null },
    { "id": "werewolf",    "name": "Werewolf",     "type": "player",          "faction": "werewolf" },
    { "id": "seer",        "name": "Seer",         "type": "player",          "faction": "village" },
    { "id": "doctor",      "name": "Doctor",       "type": "player",          "faction": "village" },
    { "id": "villager_a",  "name": "Villager A",   "type": "player",          "faction": "village" },
    { "id": "villager_b",  "name": "Villager B",   "type": "player",          "faction": "village" },
    { "id": "vote_tally",  "name": "Village Vote", "type": "game_component",  "faction": null }
  ],
  "cohorts": {
    "all_players":            ["werewolf", "seer", "doctor", "villager_a", "villager_b"],
    "village_players":        ["seer", "doctor", "villager_a", "villager_b"],
    "seer_inspect_innocents": ["doctor", "villager_a", "villager_b"],
    "doctor_protect_targets": ["werewolf", "seer", "villager_a", "villager_b"]
  },
  "rules": [
    {
      "id": "r01",
      "rule_name": "role_is_secret",
      "rule_type": "prohibition",
      "authority_entity": "moderator",
      "subject_entity": "@all_players",
      "authority_utility": 0,
      "subject_utility": -1,
      "description": "No player may reveal their role to other players"
    },
    {
      "id": "r02",
      "rule_name": "werewolf_may_eliminate",
      "rule_type": "permission",
      "authority_entity": "moderator",
      "subject_entity": "werewolf",
      "authority_utility": 0,
      "subject_utility": 1,
      "affected_entity": "@village_players",
      "affected_utility": -1,
      "description": "Each night the Werewolf may choose to eliminate any one village player"
    },
    {
      "id": "r03",
      "rule_name": "seer_may_inspect_werewolf",
      "rule_type": "permission",
      "authority_entity": "moderator",
      "subject_entity": "seer",
      "authority_utility": 0,
      "subject_utility": 1,
      "affected_entity": "werewolf",
      "affected_utility": -1,
      "description": "Each night the Seer may learn one player's role — inspecting the Werewolf exposes them"
    },
    {
      "id": "r04",
      "rule_name": "seer_may_inspect_innocent",
      "rule_type": "permission",
      "authority_entity": "moderator",
      "subject_entity": "seer",
      "authority_utility": 0,
      "subject_utility": 1,
      "affected_entity": "@seer_inspect_innocents",
      "affected_utility": 0,
      "description": "Each night the Seer may learn one player's role — inspecting an innocent confirms them safe"
    },
    {
      "id": "r05",
      "rule_name": "doctor_may_protect",
      "rule_type": "permission",
      "authority_entity": "moderator",
      "subject_entity": "doctor",
      "authority_utility": 0,
      "subject_utility": 1,
      "affected_entity": "@doctor_protect_targets",
      "affected_utility": 1,
      "description": "Each night the Doctor may protect any player from the Werewolf's elimination — without knowing roles, they may unknowingly protect the Werewolf"
    },
    {
      "id": "r06",
      "rule_name": "must_cast_vote",
      "rule_type": "obligation",
      "authority_entity": "moderator",
      "subject_entity": "@all_players",
      "authority_utility": 0,
      "subject_utility": 1,
      "affected_entity": "vote_tally",
      "affected_utility": -1,
      "description": "During the day each player must cast exactly one vote nominating another player for elimination"
    },
    {
      "id": "r07",
      "rule_name": "vote_may_eliminate",
      "rule_type": "obligation",
      "authority_entity": "moderator",
      "subject_entity": "@all_players",
      "authority_utility": 0,
      "subject_utility": -1,
      "affected_entity": "vote_tally",
      "affected_utility": 0,
      "description": "The player who receives the most votes at end of day must leave the game"
    },
    {
      "id": "r08",
      "rule_name": "village_wins_if_werewolf_eliminated",
      "rule_type": "permission",
      "authority_entity": "moderator",
      "subject_entity": "@village_players",
      "authority_utility": 0,
      "subject_utility": 1,
      "description": "The village wins when all Werewolves have been eliminated"
    },
    {
      "id": "r09",
      "rule_name": "werewolf_wins_when_equal_villagers",
      "rule_type": "permission",
      "authority_entity": "moderator",
      "subject_entity": "werewolf",
      "authority_utility": 0,
      "subject_utility": 1,
      "description": "The Werewolf wins when werewolves equal or outnumber the surviving villagers"
    }
  ]
}
